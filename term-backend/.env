POSTGRES_DB="postgres"
POSTGRES_SERVERS="postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}"

REDIS_SERVER="redis://redis-local:6379"

