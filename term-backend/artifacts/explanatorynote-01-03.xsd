    <xs:simpleType name="tEmail">
        <xs:annotation>
            <xs:documentation xml:lang="ru">Текстовая строка - адрес электронной почты</xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:normalizedString">
            <xs:pattern value="[a-zA-Zа-яА-Я0-9_.\-]{1,}[@]{1}[a-zA-Zа-яА-Я0-9_.\-]{1,}[.]{1}[a-zA-Zа-яА-Я]{2,}"/>
