    <!-- Описание простых типов -->

    <xs:simpleType name="tSchemaVersion">
        <xs:annotation>
            <xs:documentation xml:lang="ru">Номер версии, использованной при формировании пояснительной записки в формате xx.xx</xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:string">
            <xs:pattern value="([0-9]){2}\.([0-9]){2}"/>
        </xs:restriction>
    </xs:simpleType>

    <xs:simpleType name="string50">
        <xs:annotation>
            <xs:documentation xml:lang="ru">Текстовая строка длиной 50 символов</xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:normalizedString">
